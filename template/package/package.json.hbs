{
  "name": "@moon/{{packageName}}",
  "version": "1.0.0",
  "description": "{{description}}",
  "keywords": [
    "{{packageName}}"
  ],
  "author": "Mallory Scotton <mallory.scotton@epitech.eu>",
  "homepage": "https://github.com/moon-software-team/moon-ui",
  "license": "MIT",
  "main": "src/index.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moon-software-team/moon-ui",
    "directory": "packages/{{outDir}}/{{packageName}}"
  },
  "bugs": {
    "url": "https://github.com/moon-software-team/moon-ui/issues"
  },
  "scripts": {
    "build": "tsup src --dts",
    "build:fast": "tsup src",
    "dev": "pnpm run build:fast --watch",
    "clean": "rimraf dist .turbo",
    "typecheck": "tsc --noEmit",
    "prepack": "clean-package",
    "postpack": "clean-package restore"
  }
}
