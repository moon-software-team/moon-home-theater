{
  "name": "moon-home-theater",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "author": {
    "name": "Mallory Scotton",
    "email": "mallory.scotton@gmail.com",
    "url": "https://github.com/mallory-scotton"
  },
  "license": "MIT",
  "keywords": [
    "home-theater",
    "media",
    "movie",
    "film",
    "tv-shows",
    "server"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moon-software-team/moon-home-theater"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "engines": {
    "node": ">=20.x",
    "pnpm": ">=9.x"
  },
  "scripts": {
    "dev": "pnpm sb",
    "build": "turbo build --filter=!@moon/docs --filter=!@moon/storybook",
    "build:fast": "turbo build:fast --filter=!@moon/docs --filter=!@moon/storybook",
    "dev:docs": "turbo dev --filter=@moon/docs",
    "build:docs": "turbo build --filter=@moon/docs",
    "start:docs": "turbo start --filter=@moon/docs",
    "deploy:docs": "pnpm --filter @moon/docs deploy",
    "deploy:stage-docs": "pnpm --filter @moon/docs deploy:stage",
    "sb": "pnpm --filter @moon/storybook dev",
    "build:sb": "pnpm --filter @moon/storybook build",
    "start:sb": "pnpm --filter @moon/storybook start",
    "test": "jest --verbose --config ./jest.config.js",
    "test:strict": "cross-env STRICT_MODE=true pnpm test",
    "typecheck": "turbo typecheck",
    "lint": "pnpm lint:pkg && pnpm lint:docs",
    "lint:pkg": "eslint -c .eslintrc.json ./packages/**/*.{ts,tsx}",
    "lint:docs": "eslint -c .eslintrc.json ./apps/docs/**/*.{ts,tsx,js,jsx}",
    "lint:fix": "eslint --fix -c .eslintrc.json ./packages/**/*.{ts,tsx}",
    "lint:docs-fix": "eslint --fix -c .eslintrc.json ./apps/docs/**/*.{ts,tsx,js,jsx}",
    "format:check": "prettier --check packages/**/**/src --cache",
    "format:write": "prettier --write packages/**/**/src --cache",
    "turbo:clean": "turbo clean && rimraf ./node_modules/.cache/turbo",
    "turbo:graph": "pnpm build --graph=dependency-graph.png",
    "clean": "pnpm turbo:clean && pnpm clean:jest && pnpm clean:lock && pnpm clean:node-modules && pnpm install --hoist",
    "clean:node-modules": "rimraf ./apps/**/node_modules && rimraf ./packages/**/**/node_modules && rimraf ./node_modules",
    "clean:changelogs": "rimraf ./packages/**/**/CHANGELOG.md",
    "clean:lock": "rimraf ./pnpm-lock.yaml",
    "clean:jest": "jest --clearCache",
    "create:pck": "plop package",
    "create:cmp": "plop component",
    "postinstall": "husky install"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@swc/core": "^1.10.1",
    "@swc/jest": "^0.2.37",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "plop": "^4.0.1",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0"
}
