{
  "name": "@moon/filename-parser",
  "version": "1.0.0",
  "description": "Utility package to parse informations such as title and year from torrent type filename",
  "keywords": [
    "filename-parser"
  ],
  "author": "Mallory Scotton <mallory.scotton@epitech.eu>",
  "homepage": "https://github.com/moon-software-team/moon-ui",
  "license": "MIT",
  "main": "src/index.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moon-software-team/moon-ui",
    "directory": "packages/utilities/filename-parser"
  },
  "bugs": {
    "url": "https://github.com/moon-software-team/moon-ui/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean:build": "rimraf ./dist",
    "dev": "nodemon",
    "lint": "eslint . --ext .js,.ts,.jsx,.tsx",
    "lint:fix": "pnpm lint --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "jest",
    "typecheck": "tsc"
  }
}
